{
  "manifest_version": 3,
  "name": "PostPatina",
  "version": "1.4.0",
  "description": "Tints posts on X by age so yesterday's breaking news looks its age.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "PostPatina",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": ["age-utils.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
